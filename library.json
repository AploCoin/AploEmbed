{
  "name": "AploEmbed",
  "version": "0.0.1",
  "description": "AploCoin blockchain interface for embedded Arduino devices.",
  "keywords": [
    "AploCoin",
    "AploEmbed",
    "Blockchain",
    "Embedded",
    "ESP32",
    "ESP8266",
    "Arduino",
    "RPC",
    "Staking",
    "Mining"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AploCoin/AploEmbed.git"
  },
  "authors": [
    {
      "name": "AploSDK Team",
      "url": "https://github.com/AploCoin",
      "maintainer": true
    },
    {
      "name": "James Brown (original author)",
      "url": "https://github.com/JamesSmartCell"
    }
  ],
  "frameworks": "arduino",
  "platforms": [
    "espressif32",
    "espressif8266"
  ],
  "export": {
    "include": [
      "src",
      "examples",
      "docs",
      "README.md",
      "library.json",
      "library.properties",
      "keywords.txt",
      "LICENSE"
    ],
    "exclude": [
      "examples/**/.pio",
      "examples/**/.pio/**"
    ]
  },
  "homepage": "https://aplocoin.com/"
}
